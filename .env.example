OPENAI_API_KEY=
TRANSCRIPTION_MODEL=gpt-4o-transcribe
ADVICE_MODEL=gpt-5.4-mini
ADVICE_REASONING_EFFORT=none
PORT=8787
VITE_API_PROXY_TARGET=http://127.0.0.1:8787

# Optional: send generated speech to AITuberKit's direct-speak API.
# Configure the same API key and client ID as ~/WorkSpace/aituber-kit.
AITUBERKIT_BASE_URL=http://127.0.0.1:3000
AITUBERKIT_API_KEY=
AITUBERKIT_CLIENT_ID=
AITUBERKIT_SPEAK_INTERRUPT=true
AITUBERKIT_SPEAK_PRIORITY=high
AITUBERKIT_SPEAK_TIMEOUT_MS=3000
