{
  "name": "pokemon-battle-partner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "data:champions": "tsx scripts/generate-champions-data.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:knowledge",
    "test:knowledge": "node tests/knowledge-files.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.4",
    "@mastra/core": "^1.47.0",
    "@pkmn/data": "^0.10.11",
    "@pkmn/dex": "^0.10.11",
    "@smogon/calc": "^0.11.0",
    "@vitejs/plugin-react": "^5.1.1",
    "ai": "^7.0.8",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "multer": "^2.0.2",
    "openai": "^6.45.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
