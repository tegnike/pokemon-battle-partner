{
  "name": "pokemon-battle-partner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "data:champions": "tsx scripts/generate-champions-data.ts",
    "data:champions:refresh": "npm run data:champions:availability && npm run data:champions:move-ja-aliases && npm run data:champions:pokemon-ja-aliases && npm run data:champions",
    "data:champions:availability": "tsx scripts/import-champions-move-availability.ts",
    "data:champions:move-ja-aliases": "tsx scripts/import-move-ja-aliases.ts",
    "data:champions:pokemon-ja-aliases": "tsx scripts/import-pokemon-ja-aliases.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:knowledge && npm run test:speed && npm run test:champions-data && npm run test:field-status && npm run test:field-state && npm run test:phase && npm run test:names && npm run test:turn-eval",
    "test:turn-eval": "tsx tests/turn-evaluation.test.mjs",
    "test:field-state": "tsx tests/field-state.test.mjs",
    "test:phase": "tsx tests/phase-regression.test.mjs",
    "test:names": "tsx tests/name-resolution.test.mjs",
    "test:integration": "tsx tests/integration/battle-replay.integration.mjs",
    "eval:advice": "tsx scripts/eval-advice.ts",
    "fixtures:replays": "tsx scripts/export-battle-replay-fixtures.ts",
    "test:knowledge": "node tests/knowledge-files.test.mjs",
    "test:speed": "tsx tests/speed-comparison.test.mjs",
    "test:champions-data": "node tests/champions-data.test.mjs",
    "test:field-status": "tsx tests/field-status.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.4",
    "@mastra/core": "^1.47.0",
    "@pkmn/data": "^0.10.11",
    "@pkmn/dex": "^0.10.11",
    "@smogon/calc": "^0.11.0",
    "@vitejs/plugin-react": "^5.1.1",
    "ai": "^7.0.8",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "multer": "^2.0.2",
    "openai": "^6.45.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
